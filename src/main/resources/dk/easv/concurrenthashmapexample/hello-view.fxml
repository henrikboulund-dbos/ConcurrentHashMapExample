<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.concurrenthashmapexample.HelloController"
            prefWidth="860" prefHeight="620">

    <!-- ─── Header ─── -->
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 12 20 12 20;">
            <Label text="ConcurrentHashMap — Thread Safety Demo"
                   style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
            <Label text="Multiple threads increment word counts via merge() — no explicit locks required"
                   style="-fx-text-fill: #bdc3c7; -fx-font-size: 12;"/>
        </VBox>
    </top>

    <!-- ─── Main area ─── -->
    <center>
        <SplitPane dividerPositions="0.3">

            <!-- LEFT: Control panel -->
            <VBox spacing="10" minWidth="200"
                  style="-fx-padding: 15; -fx-background-color: #f4f4f4;">

                <Label text="Controls" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                <Separator/>

                <Label text="Number of threads:"/>
                <Spinner fx:id="thread_count_spinner" prefWidth="130" editable="false"/>

                <Button fx:id="start_button" text="▶  Start Threads" maxWidth="Infinity"
                        onAction="#on_start_clicked"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 4 8 4;"/>
                <Button fx:id="stop_button" text="■  Stop Threads" maxWidth="Infinity"
                        onAction="#on_stop_clicked"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 4 8 4;"/>
                <Button fx:id="clear_button" text="✕  Clear Map" maxWidth="Infinity"
                        onAction="#on_clear_clicked"
                        style="-fx-background-color: #7f8c8d; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-padding: 8 4 8 4;"/>

                <Separator/>

                <!-- Live stats -->
                <GridPane hgap="8" vgap="5">
                    <Label text="Status:" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <Label fx:id="status_label" text="Stopped"
                           style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;"
                           GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Active threads:" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label fx:id="threads_label" text="0"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Total ops:" style="-fx-font-weight: bold;"
                           GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <Label fx:id="operations_label" text="0"
                           GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                </GridPane>

                <Separator/>

                <!-- Explanation -->
                <Label text="How it works:" style="-fx-font-weight: bold;"/>
                <Label maxWidth="Infinity" wrapText="true"
                       style="-fx-font-size: 11; -fx-text-fill: #444;"
                       text="Each thread calls:&#10;  map.merge(word, 1, Integer::sum)&#10;&#10;This is an atomic operation — ConcurrentHashMap guarantees no updates are lost, even without synchronized blocks."/>
            </VBox>

            <!-- RIGHT: Live map + log -->
            <VBox spacing="8" style="-fx-padding: 15;">

                <Label text="Map Contents  (refreshed every 400 ms)"
                       style="-fx-font-size: 13; -fx-font-weight: bold;"/>

                <TableView fx:id="map_table" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="key_column"    text="Word (Key)"       prefWidth="170"/>
                        <TableColumn fx:id="value_column"  text="Count (Value)"    prefWidth="140"/>
                        <TableColumn fx:id="thread_column" text="Last Updated By"  prefWidth="170"/>
                    </columns>
                    <placeholder>
                        <Label text="Map is empty — press Start Threads to populate"/>
                    </placeholder>
                </TableView>

                <Label text="Activity Log"
                       style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                <TextArea fx:id="log_area" prefRowCount="7" editable="false"
                          VBox.vgrow="ALWAYS"
                          style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 11;"/>
            </VBox>

        </SplitPane>
    </center>

</BorderPane>